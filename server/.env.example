# Gemini 2.5 Flash — research notes & question generation
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash

# Legacy: keys starting with AIza in OPENAI_API_KEY are also detected
OPENAI_API_KEY=

# Server
PORT=3001
CLIENT_URL=http://localhost:5173

# Production (Coolify) — must match your frontend URL exactly (no trailing slash)
# CLIENT_URL=https://assessment.graylogic.cloud
# Optional: comma-separated extra origins
# CORS_ORIGINS=https://assessment.graylogic.cloud,http://localhost:5173
