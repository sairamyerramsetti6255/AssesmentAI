GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash
# When OpenRouter free tier hits 50/day limit, auto-use Gemini if key is set (set false to disable)
AI_GEMINI_FALLBACK=true

# Legacy: keys starting with AIza in OPENAI_API_KEY are also detected
OPENAI_API_KEY=

# OpenRouter (prototype manager setup — paste key in server/.env only, never commit)
# https://openrouter.ai/keys
OPENROUTER_API_KEY=
# Non-reasoning model recommended — uses fewer tokens, better JSON (free tier: 50 requests/day total)
OPENROUTER_MODEL=google/gemma-3-12b-it:free
OPENROUTER_JSON_MODEL=google/gemma-3-12b-it:free
OPENROUTER_SITE_URL=http://localhost:5173
OPENROUTER_APP_NAME=AI Readiness Assessment

# Server
PORT=3001
CLIENT_URL=http://localhost:5173

# Production (Coolify) — must match your frontend URL exactly (no trailing slash)
# CLIENT_URL=https://assessment.pbshope.in
# Optional: comma-separated extra origins
# CORS_ORIGINS=https://assessment.pbshope.in
# Debug only: CORS_ALLOW_ALL=true
