# Local development
# Leave VITE_API_URL empty/unset so the app uses "/api",
# which Vite proxies to the local server at http://localhost:3001.
# VITE_API_URL=

# To test against the remote/production API from local, uncomment:
# VITE_API_URL=https://zo0go8484gkscgo0o4o8o0s4.api.pbshope.in/api

# Coolify / production: set at build time (see .env.production)
# VITE_API_URL=https://your-api-domain.pbshope.in/api

# Demo mode (default on): rich sample data instead of live AI. Set false when Gemini works.
# VITE_DEMO_MODE=true
