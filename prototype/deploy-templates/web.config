<?xml version="1.0" encoding="UTF-8"?>
<!--
  IIS reverse proxy to Node (server.mjs on 127.0.0.1:4173).
  Requires: URL Rewrite + Application Request Routing (ARR), proxy enabled.
  API key stays in .env on the server — never in dist/ or this file.
-->
<configuration>
  <system.webServer>
    <rewrite>
      <rules>
        <rule name="ReverseProxyToNode" stopProcessing="true">
          <match url="(.*)" />
          <action type="Rewrite" url="http://127.0.0.1:4173/{R:1}" />
        </rule>
      </rules>
    </rewrite>
    <httpProtocol>
      <customHeaders>
        <remove name="X-Powered-By" />
      </customHeaders>
    </httpProtocol>
  </system.webServer>
</configuration>
