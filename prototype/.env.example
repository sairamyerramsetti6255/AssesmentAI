# Copy to .env and set your real key (never commit .env)
# Get a key: https://openrouter.ai/keys

# Paste key with NO quotes: OPENROUTER_API_KEY=sk-or-v1-abc123
OPENROUTER_API_KEY=

# Free model (required for this prototype — do not change unless you intend a paid model)
OPENROUTER_MODEL=nvidia/nemotron-3-nano-omni-30b-a3b-reasoning:free

# Optional — sent as OpenRouter attribution headers
OPENROUTER_SITE_URL=http://localhost:5173
OPENROUTER_APP_NAME=AI Readiness Assessment
